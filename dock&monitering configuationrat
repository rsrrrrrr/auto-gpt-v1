# scripts/backup.sh
#!/bin/bash

echo "💾 AutoGPT 데이터 백업 시작..."

BACKUP_DIR="backups/$(date +%Y%m%d_%H%M%S)"
mkdir -p "$BACKUP_DIR"

# 데이터베이스 백업
echo "🗄️  데이터베이스 백업 중..."
docker-compose exec postgres pg_dump -U autogpt autogpt > "$BACKUP_DIR/database.sql"

# Redis 데이터 백업
echo "📊 Redis 데이터 백업 중..."
docker-compose exec redis redis-cli --rdb "$BACKUP_DIR/redis.rdb"

# 로그 파일 백업
echo "📋 로그 파일 백업 중..."
cp -r logs "$BACKUP_DIR/"

# 설정 파일 백업
echo "⚙️  설정 파일 백업 중..."
cp .env "$BACKUP_DIR/"
cp docker-compose.yml "$BACKUP_DIR/"

# 압축
echo "🗜️  백업 파일 압축 중..."
tar -czf "${BACKUP_DIR}.tar.gz" "$BACKUP_DIR"
rm -rf "$BACKUP_DIR"

echo "✅ 백업 완료: ${BACKUP_DIR}.tar.gz"

