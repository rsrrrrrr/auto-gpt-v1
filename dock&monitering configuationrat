sleep 10

services=("autogpt-api" "autogpt-celery-worker" "autogpt-redis" "autogpt-postgres" "autogpt-prometheus" "autogpt-grafana")

for service in "${services[@]}"; do
    if docker-compose ps | grep -q "$service.*Up"; then
        echo "✅ $service: 실행 중"
    else
        echo "❌ $service: 실행 실패"
        docker-compose logs "$service"
    fi
done

echo ""
echo "🎉 배포 완료!"
echo ""
echo "📊 서비스 URL:"
echo "  • 메인 애플리케이션: http://localhost"
