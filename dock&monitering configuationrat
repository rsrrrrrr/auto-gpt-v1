#!/bin/bash

echo "📊 AutoGPT 시스템 모니터링..."

while true; do
    clear
    echo "=== AutoGPT System Monitor ==="
    echo "시간: $(date)"
    echo ""
    
    # Docker 컨테이너 상태
    echo "🐳 Docker 컨테이너 상태:"
    docker-compose ps
    echo ""
    
    # 시스템 리소스
    echo "💻 시스템 리소스:"
    echo "CPU: $(top -bn1 | grep "Cpu(s)" | awk '{print $2}' | awk -F'%' '{print $1}')%"
    echo "메모리: $(free -h | awk 'NR==2{printf "%.1f%%", $3*100/$2 }')"
    echo "디스크: $(df -h | awk '$NF=="/"{printf "%s", $5}')"
    echo ""
    
    # 활성 연결
    echo "🔗 네트워크 연결:"
    netstat -an | grep :8000 | wc -l | xargs echo "Port 8000 연결 수:"
    netstat -an | grep :3000 | wc -l | xargs echo "Port 3000 연결 수:"
    echo ""
    
    # 최근 로그 (에러만)
    echo "🚨 최근 에러 로그:"
    tail -5 logs/autogpt_production.log | grep -i error || echo "에러 없음"
    echo ""
    
    echo "Press Ctrl+C to exit"
    sleep 5
done
