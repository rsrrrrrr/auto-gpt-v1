# docker-compose.yml
version: '3.8'

services:
  # Redis (메시지 브로커 & 캐시)
  redis:
    image: redis:7-alpine
    container_name: autogpt-redis
    restart: unless-stopped
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    command: redis-server --appendonly yes
    networks:
      - autogpt-network

  # PostgreSQL (메인 데이터베이스)
  postgres:
    image: postgres:15-alpine
    container_name: autogpt-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: autogpt
      POSTGRES_PASSWORD: autogpt_password
      POSTGRES_DB: autogpt
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    networks:
      - autogpt-network

  # AutoGPT 메인 애플리케이션
  autogpt-api:
    build:
      context: .
      dockerfile: Dockerfile.api
    container_name: autogpt-api
    restart: unless-stopped
    environment:
      - DATABASE_URL=postgresql://autogpt:autogpt_password@postgres:5432/autogpt
      - REDIS_URL=redis://redis:6379/0
      - OPENAI_API_KEY=${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}
      - ANTHROPIC_API_KEY=${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}
      - ENABLE_SANDBOX=true
      - WEB_HOST=0.0.0.0
      - WEB_PORT=8000
    ports:
      - "8000:8000"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - ./logs:/app/logs
    depends_on:
      - redis
      - postgres
    networks:
      - autogpt-network

  # Celery Worker (분산 작업 처리)
  celery-worker:
    build:
      context: .
      dockerfile: Dockerfile.api
    container_name: autogpt-celery-worker
    restart: unless-stopped
    command: celery -A main.celery_app worker --loglevel=info --concurrency=4
    environment:
      - DATABASE_URL=postgresql://autogpt:autogpt_password@postgres:5432/autogpt
      - REDIS_URL=redis://redis:6379/0
      - OPENAI_API_KEY=${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}
      - ANTHROPIC_API_KEY=${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}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - ./logs:/app/logs
    depends_on:
      - redis
      - postgres
    networks:
      - autogpt-network

  # Celery Beat (스케줄러)
  celery-beat:
    build:
      context: .
      dockerfile: Dockerfile.api
    container_name: autogpt-celery-beat
    restart: unless-stopped
    command: celery -A main.celery_app beat --loglevel=info
    environment:
      - DATABASE_URL=postgresql://autogpt:autogpt_password@postgres:5432/autogpt
      - REDIS_URL=redis://redis:6379/0
    depends_on:
      - redis
      - postgres
    networks:
      - autogpt-network

  # React 프론트엔드
  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: autogpt-frontend
    restart: unless-stopped
    ports:
      - "3000:80"
    depends_on:
      - autogpt-api
    networks:
      - autogpt-network

  # Prometheus (메트릭 수집)
  prometheus:
    image: prom/prometheus:latest
    container_name: autogpt-prometheus
    restart: unless-stopped
    ports:
      - "9090:9090"
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml
      - prometheus_data:/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.console.libraries=/etc/prometheus/console_libraries'
      - '--web.console.templates=/etc/prometheus/consoles'
      - '--storage.tsdb.retention.time=200h'
      - '--web.enable-lifecycle'
    networks:
      - autogpt-network

  # Grafana (대시보드)
  grafana:
    image: grafana/grafana:latest
    container_name: autogpt-grafana
    restart: unless-stopped
    ports:
      - "3001:3000"
    environment:
      - GF_SECURITY_ADMIN_USER=admin
      - GF_SECURITY_ADMIN_PASSWORD=admin123
      - GF_USERS_ALLOW_SIGN_UP=false
    volumes:
      - grafana_data:/var/lib/grafana
      - ./monitoring/grafana/provisioning:/etc/grafana/provisioning
      - ./monitoring/grafana/dashboards:/var/lib/grafana/dashboards
    depends_on:
      - prometheus
    networks:
      - autogpt-network

  # Nginx (리버스 프록시)
  nginx:
    image: nginx:alpine
    container_name: autogpt-nginx
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf
      - ./nginx/ssl:/etc/nginx/ssl
    depends_on:
      - autogpt-api
      - frontend
      - grafana
    networks:
      - autogpt-network

volumes:
  redis_data:
  postgres_data:
  prometheus_data:
  grafana_data:

networks:
  autogpt-network:
    driver: bridge

---

# Dockerfile.api
FROM python:3.11-slim

WORKDIR /app

# 시스템 패키지 업데이트
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Docker CLI 설치 (샌드박스용)
RUN curl -fsSL https://get.docker.com -o get-docker.sh && sh get-docker.sh

# Python 의존성 설치
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 애플리케이션 코드 복사
COPY . .

# 헬스체크
HEALTHCHECK --interval=30s --timeout=30s --start-period=5s --retries=3 \
  CMD curl -f http://localhost:8000/api/status || exit 1

EXPOSE 8000

CMD ["python", "main.py"]

---

# frontend/Dockerfile
FROM node:18-alpine as builder

WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production

COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]

---

# monitoring/prometheus.yml
global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - "alert_rules.yml"

scrape_configs:
  - job_name: 'autogpt-api'
    static_configs:
      - targets: ['autogpt-api:8000']
    metrics_path: '/api/metrics'
    scrape_interval: 5s

  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:9090']

  - job_name: 'redis'
    static_configs:
      - targets: ['redis:6379']

  - job_name: 'postgres'
    static_configs:
      - targets: ['postgres:5432']

alerting:
  alertmanagers:
    - static_configs:
        - targets:
          - alertmanager:9093

---

# monitoring/alert_rules.yml
groups:
  - name: autogpt_alerts
    rules:
      - alert: HighCPUUsage
        expr: autogpt_cpu_usage_percent > 80
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "AutoGPT CPU usage is high"
          description: "CPU usage has been above 80% for more than 5 minutes"

      - alert: HighMemoryUsage
        expr: autogpt_memory_usage_bytes > 1000000000  # 1GB
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "AutoGPT memory usage is high"
          description: "Memory usage has exceeded 1GB for more than 5 minutes"

      - alert: TaskFailureRate
        expr: rate(autogpt_tasks_total{status="failed"}[5m]) > 0.1
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "High task failure rate"
          description: "Task failure rate is above 10% for 2 minutes"

      - alert: ServiceDown
        expr: up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Service is down"
          description: "{{ $labels.instance }} has been down for more than 1 minute"

