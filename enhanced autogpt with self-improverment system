@app.post("/api/goals")
async def create_goal(
    description: str,
    success_criteria: List[str],
    priority: int = 1,
    deadline: Optional[str] = None,
    use_llm: bool = True
):
    """새로운 목표 생성"""
    deadline_dt = datetime.fromisoformat(deadline) if deadline else None
    goal_id = await autogpt_instance.add_goal_advanced(
        description, success_criteria, priority, deadline_dt, use_llm
    )
