@app.websocket("/ws")
async def websocket_endpoint(websocket: WebSocket):
    """WebSocket 연결"""
    await websocket.accept()
    autogpt_instance.websocket_connections.append(websocket)
    
    try:
        while True:
            await websocket.receive_text()
    except Exception:
        pass
    finally:
        if websocket in autogpt_instance.websocket_connections:
            autogpt_instance.websocket_connections.remove(websocket)

