# LLM 통합 시스템
class LLMIntegration:
    """LLM API 통합 (OpenAI + Anthropic)"""
    
    def __init__(self):
        self.openai_client = None
        self.anthropic_client = None
        
        if config.OPENAI_API_KEY:
            self.openai_client = openai.OpenAI(api_key=config.OPENAI_API_KEY)
            
        if config.ANTHROPIC_API_KEY:
            self.anthropic_client = anthropic.Anthropic(api_key=config.ANTHROPIC_API_KEY)
        
        logger.info("LLM 통합 초기화 완료")
    
    async def decompose_goal_with_llm(self, goal_description: str, context: str = "") -> List[Dict]:
        """LLM을 사용한 지능적 목표 분해"""
        prompt = f"""
        목표: {goal_description}
        컨텍스트: {context}
        
        이 목표를 달성하기 위한 구체적이고 실행 가능한 작업들로 분해해주세요.
        각 작업은 다음 형식으로 응답해주세요:
        
        [
          {{
            "description": "작업 설명",
            "priority": 1-5 (숫자),
            "estimated_difficulty": 0.1-1.0 (소수),
            "dependencies": ["의존하는 작업 설명들"],
            "tools_needed": ["필요한 도구들"]
          }}
        ]
        
        JSON 형식으로만 응답해주세요.
        """
        
        try:
            if self.openai_client:
                response = await self._query_openai(prompt)
            elif self.anthropic_client:
                response = await self._query_anthropic(prompt)
            else:
                raise Exception("LLM API가 설정되지 않음")
            
            return json.loads(response)
            
        except Exception as e:
            logger.error(f"LLM 목표 분해 실패: {e}")
            return self._fallback_decomposition(goal_description)
    
    async def _query_openai(self, prompt: str) -> str:
        """OpenAI API 쿼리"""
        response = await self.openai_client.chat.completions.acreate(
            model="gpt-4",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=2000,
            temperature=0.7
        )
        return response.choices[0].message.content
    
    async def _query_anthropic(self, prompt: str) -> str:
        """Anthropic API 쿼리"""
        response = await self.anthropic_client.messages.acreate(
            model="claude-3-sonnet-20240229",
            max_tokens=2000,
            messages=[{"role": "user", "content": prompt}]
        )
        return response.content[0].text
    
    def _fallback_decomposition(self, goal_description: str) -> List[Dict]:
        """LLM 실패 시 폴백 분해"""
        return [
            {
                "description": f"분석 및 계획: {goal_description}",
                "priority": 1,
                "estimated_difficulty": 0.3,
                "dependencies": [],
                "tools_needed": ["analysis"]
            },
            {
                "description": f"실행: {goal_description}",
                "priority": 2,
                "estimated_difficulty": 0.7,
                "dependencies": ["분석 및 계획"],
                "tools_needed": ["execution"]
            },
            {
                "description": f"검증 및 완료: {goal_description}",
                "priority": 3,
                "estimated_difficulty": 0.4,
                "dependencies": ["실행"],
                "tools_needed": ["validation"]
            }
        ]

# 보안 샌드박스 시스템
class SecuritySandbox:
    """Docker 기반 보안 샌드박스"""
    
    def __init__(self):
        self.docker_client = None
        if config.ENABLE_SANDBOX:
            try:
                self.docker_client = docker.from_env()
                logger.info("Docker 샌드박스 초기화 완료")
            except Exception as e:
                logger.warning(f"Docker 연결 실패: {e}")
                self.docker_client = None
    
    async def execute_code_safely(self, code: str, language: str = "python", 
                                 timeout: int = 30) -> Dict[str, Any]:
        """안전한 코드 실행"""
        if not self.docker_client:
            return await self._execute_local_safe(code, language, timeout)
        
        try:
            # 임시 디렉토리 생성
            with tempfile.TemporaryDirectory() as temp_dir:
                code_file = Path(temp_dir) / f"code.{self._get_extension(language)}"
                code_file.write_text(code)
                
                # Docker 컨테이너 실행
                container = self.docker_client.containers.run(
                    config.DOCKER_SANDBOX_IMAGE,
                    command=self._get_exec_command(language, "/code/code." + self._get_extension(language)),
                    volumes={temp_dir: {"bind": "/code", "mode": "ro"}},
                    network_disabled=True,
                    mem_limit="128m",
                    cpu_period=100000,
                    cpu_quota=50000,  # 50% CPU
                    detach=True,
                    remove=True
                )
                
                # 결과 대기
                result = container.wait(timeout=timeout)
                logs = container.logs().decode()
                
                return {
                    "success": result["StatusCode"] == 0,
                    "output": logs,
                    "exit_code": result["StatusCode"]
                }
                
        except Exception as e:
            logger.error(f"샌드박스 실행 실패: {e}")
            return {"success": False, "error": str(e)}
    
    async def _execute_local_safe(self, code: str, language: str, timeout: int) -> Dict[str, Any]:
        """로컬 안전 실행 (제한적)"""
        if language != "python":
            return {"success": False, "error": "Python만 지원됩니다"}
        
        # 위험한 키워드 검사
        dangerous_keywords = ["import os", "import sys", "__import__", "exec", "eval", "open("]
        if any(keyword in code for keyword in dangerous_keywords):
            return {"success": False, "error": "위험한 코드가 감지되었습니다"}
        
        try:
            # 제한된 환경에서 실행
            restricted_globals = {
                "__builtins__": {
                    "print": print,
                    "len": len,
                    "str": str,
                    "int": int,
                    "float": float,
                    "list": list,
                    "dict": dict,
                    "range": range,
                    "sum": sum,
                    "max": max,
                    "min": min
                }
            }
            
            exec(code, restricted_globals)
            return {"success": True, "output": "코드 실행 완료"}
            
        except Exception as e:
            return {"success": False, "error": str(e)}
    
    def _get_extension(self, language: str) -> str:
        extensions = {"python": "py", "javascript": "js", "bash": "sh"}
        return extensions.get(language, "txt")
    
    def _get_exec_command(self, language: str, filepath: str) -> str:
        commands = {
            "python": f"python {filepath}",
            "javascript": f"node {filepath}",
            "bash": f"bash {filepath}"
        }
        return commands.get(language, f"cat {filepath}")

