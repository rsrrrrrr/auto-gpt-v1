# 분산 작업 정의
@celery_app.task(bind=True, max_retries=3)
def execute_task_distributed(self, task_data: Dict) -> Dict:
    """분산 작업 실행"""
    try:
        task_counter.labels(status="started", type=task_data.get("type", "unknown")).inc()
        
        start_time = time.time()
        
        # 작업 실행 로직
        result = _execute_task_logic(task_data)
        
        duration = time.time() - start_time
        task_duration.observe(duration)
        task_counter.labels(status="completed", type=task_data.get("type", "unknown")).inc()
        
        return {"success": True, "result": result, "duration": duration}
        
    except Exception as exc:
        task_counter.labels(status="failed", type=task_data.get("type", "unknown")).inc()
        logger.error(f"분산 작업 실패: {exc}")
        
        # 재시도 로직
        if self.request.retries < self.max_retries:
            raise self.retry(countdown=60 * (self.request.retries + 1))
        
        return {"success": False, "error": str(exc)}

def _execute_task_logic(task_data: Dict) -> str:
    """실제 작업 실행 로직"""
    # 시뮬레이션된 작업 처리
    time.sleep(1)  # 작업 시뮬레이션
    return f"작업 완료: {task_data.get('description', 'Unknown task')}"

# 모니터링 시스템
class MonitoringSystem:
    """Prometheus 기반 모니터링"""
    
    def __init__(self):
        self.redis_client = redis.from_url(config.REDIS_URL)
        self._start_metrics_collection()
    
    def _start_metrics_collection(self):
        """메트릭 수집 시작"""
        asyncio.create_task(self._collect_system_metrics())
    
    async def _collect_system_metrics(self):
        """시스템 메트릭 수집"""
        while True:
            try:
                # CPU 사용률
                cpu_percent = psutil.cpu_percent()
                system_cpu.set(cpu_percent)
                
                # 메모리 사용률
                memory = psutil.virtual_memory()
                system_memory.set(memory.used)
                
                # Redis 메트릭
                redis_info = self.redis_client.info()
                
                await asyncio.sleep(10)  # 10초마다 수집
                
            except Exception as e:
                logger.error(f"메트릭 수집 실패: {e}")
                await asyncio.sleep(30)
    
    def get_metrics(self) -> str:
        """Prometheus 형식 메트릭 반환"""
        return generate_latest()

# 향상된 AutoGPT 메인 클래스
class ProductionAutoGPT(EnhancedAutoGPT):
    """프로덕션 환경용 AutoGPT"""
    
    def __init__(self):
        super().__init__()
        
        # 새로운 구성요소들
        self.llm_integration = LLMIntegration()
        self.security_sandbox = SecuritySandbox()
        self.monitoring = MonitoringSystem()
        
        # 데이터베이스 설정
        self.engine = create_engine(config.DATABASE_URL)
        Base.metadata.create_all(self.engine)
        self.SessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=self.engine)
        
        # WebSocket 연결 관리
        self.websocket_connections: List[WebSocket] = []
        
        logger.info("프로덕션 AutoGPT 시스템 초기화 완료")
    
    async def add_goal_advanced(self, description: str, success_criteria: List[str], 
                              priority: int = 1, deadline: Optional[datetime] = None,
                              use_llm: bool = True) -> str:
        """고급 목표 추가 (LLM 통합)"""
        goal_id = str(uuid.uuid4())
        
        # 데이터베이스에 목표 저장
        db = self.SessionLocal()
        try:
            goal_model = GoalModel(
                id=goal_id,
                description=description,
                success_criteria=json.dumps(success_criteria),
                priority=priority,
                deadline=deadline
            )
            db.add(goal_model)
            db.commit()
            
            # LLM을 사용한 작업 분해
            if use_llm:
                context = await self._get_relevant_context(description)
                llm_tasks = await self.llm_integration.decompose_goal_with_llm(description, context)
                
                # 작업을 데이터베이스에 저장
                for i, task_data in enumerate(llm_tasks):
                    task_model = TaskModel(
                        id=f"{goal_id}_task_{i}",
                        goal_id=goal_id,
                        description=task_data["description"],
                        priority=task_data["priority"],
                        estimated_difficulty=task_data["estimated_difficulty"],
                        dependencies=json.dumps(task_data.get("dependencies", []))
                    )
                    db.add(task_model)
                
                db.commit()
            
            active_goals.inc()
            
            # WebSocket으로 업데이트 전송
            await self._broadcast_update("goal_added", {
                "goal_id": goal_id,
                "description": description,
                "priority": priority
            })
            
            logger.info(f"고급 목표 추가됨: {goal_id} - {description}")
            return goal_id
            
        except Exception as e:
            db.rollback()
            raise e
        finally:
            db.close()
    
    async def _get_relevant_context(self, description: str) -> str:
        """관련 컨텍스트 검색"""
        memories = self.memory.search_long_term(description, limit=5)
        return "\n".join([mem["content"] for mem in memories])
    
    async def execute_task_with_sandbox(self, task_id: str) -> bool:
        """샌드박스를 사용한 안전한 작업 실행"""
        db = self.SessionLocal()
        try:
            task = db.query(TaskModel).filter(TaskModel.id == task_id).first()
            if not task:
                return False
            
            task.status = "in_progress"
            db.commit()
            
            # 코드 실행이 필요한 작업인지 확인
            if "코드" in task.description or "실행" in task.description:
                # 샌드박스에서 안전하게 실행
                code = self._extract_code_from_description(task.description)
                if code:
                    result = await self.security_sandbox.execute_code_safely(code)
                    task.result = json.dumps(result)
                    task.status = "completed" if result["success"] else "failed"
                else:
                    # 일반 작업 실행
                    task.result = await self._execute_general_task(task.description)
                    task.status = "completed"
            else:
                # 분산 처리로 전송
                celery_result = execute_task_distributed.delay({
                    "id": task_id,
                    "description": task.description,
                    "type": self._categorize_task(task.description)
                })
                
                # 결과 대기 (비동기적으로)
                asyncio.create_task(self._wait_for_celery_result(task_id, celery_result.id))
                return True
            
            task.completed_at = datetime.now()
            db.commit()
            
            return task.status == "completed"
            
        except Exception as e:
            logger.error(f"작업 실행 실패: {e}")
            task.status = "failed"
            db.commit()
            return False
        finally:
            db.close()
    
    def _extract_code_from_description(self, description: str) -> Optional[str]:
        """작업 설명에서 코드 추출"""
        # 간단한 코드 패턴 매칭
        if "print(" in description:
            return description
        return None
    
    async def _execute_general_task(self, description: str) -> str:
        """일반 작업 실행"""
        await asyncio.sleep(1)  # 시뮬레이션
        return f"일반 작업 완료: {description}"
    
    async def _wait_for_celery_result(self, task_id: str, celery_task_id: str):
        """Celery 결과 대기"""
        try:
            result = celery_app.AsyncResult(celery_task_id)
            while not result.ready():
                await asyncio.sleep(1)
            
            # 결과를 데이터베이스에 업데이트
            db = self.SessionLocal()
            task = db.query(TaskModel).filter(TaskModel.id == task_id).first()
            if task:
                celery_result = result.result
                task.result = json.dumps(celery_result)
                task.status = "completed" if celery_result.get("success") else "failed"
                task.completed_at = datetime.now()
                db.commit()
            db.close()
            
        except Exception as e:
            logger.error(f"Celery 결과 처리 실패: {e}")
    
    async def _broadcast_update(self, event_type: str, data: Dict):
        """WebSocket 업데이트 브로드캐스트"""
        if self.websocket_connections:
            message = json.dumps({"type": event_type, "data": data})
            for websocket in self.websocket_connections[:]:
                try:
                    await websocket.send_text(message)
                except Exception:
                    self.websocket_connections.remove(websocket)

